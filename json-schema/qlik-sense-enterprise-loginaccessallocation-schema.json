{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/LoginAccessAllocation",
  "title": "LoginAccessAllocation",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "createdDate": {
      "type": "string",
      "format": "date-time"
    },
    "modifiedDate": {
      "type": "string",
      "format": "date-time"
    },
    "user": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string"
        },
        "userDirectory": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        }
      }
    },
    "tokensUsed": {
      "type": "integer",
      "description": "Number of tokens consumed by this login access"
    },
    "schemaPath": {
      "type": "string"
    }
  }
}